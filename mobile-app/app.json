{
  "expo": {
    "name": "HumanoidMaker Ecommerce",
    "slug": "humanoidmaker-ecommerce-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f6f3ef"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.humanoidmaker.ecommerce"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.humanoidmaker.ecommerce"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-image-picker",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "appName": "HumanoidMaker Ecommerce"
    }
  }
}
